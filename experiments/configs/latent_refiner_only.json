{
  "baseline": "latent_refiner_only",
  "model": {
    "name": "example/base-instruct-model",
    "frozen_base": true,
    "standard_lora": {
      "enabled": false
    },
    "latent_refiner": {
      "enabled": true,
      "num_recurrent_steps": 2,
      "recurrence_mode": "latent_only",
      "adapter_sharing": "none"
    },
    "trainable_modules": [
      "latent_refiner"
    ]
  },
  "dataset": {
    "name": "synthetic_integer_sequences",
    "settings": {
      "num_examples": 32,
      "sequence_length": 10,
      "eval_fraction": 0.25,
      "seed": 13
    }
  },
  "training": {
    "batch_size": 4,
    "num_epochs": 1,
    "max_steps": 4,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "seed": 13,
    "eval_interval_steps": 2,
    "checkpoint_interval_steps": 2
  },
  "output": {
    "dir": "outputs/latent_refiner_only"
  }
}
