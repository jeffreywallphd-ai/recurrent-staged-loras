{
  "baseline": "standard_lora",
  "model": {
    "name": "example/base-instruct-model",
    "frozen_base": true,
    "standard_lora": {
      "enabled": true,
      "rank": 8,
      "alpha": 16,
      "dropout": 0.0,
      "target_modules": ["q_proj", "v_proj"]
    },
    "latent_refiner": {
      "enabled": false,
      "num_recurrent_steps": 1,
      "recurrence_mode": "none",
      "adapter_sharing": "none"
    },
    "trainable_modules": ["standard_lora"]
  },
  "dataset": {
    "name": "synthetic_integer_sequences",
    "settings": {
      "num_examples": 32,
      "sequence_length": 10,
      "eval_fraction": 0.25,
      "seed": 12
    }
  },
  "training": {
    "batch_size": 4,
    "num_epochs": 1,
    "max_steps": 4,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "seed": 12,
    "eval_interval_steps": 2,
    "checkpoint_interval_steps": 2
  },
  "output": {
    "dir": "outputs/standard_lora"
  }
}
