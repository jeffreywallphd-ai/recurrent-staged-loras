{
  "baseline": "shared_recurrence",
  "model": {
    "name": "example/base-instruct-model",
    "frozen_base": true,
    "standard_lora": {
      "enabled": false
    },
    "latent_refiner": {
      "enabled": true,
      "num_recurrent_steps": 3,
      "recurrence_mode": "shared",
      "adapter_sharing": "shared",
      "adapter": {
        "enabled": true,
        "rank": 8,
        "alpha": 16,
        "dropout": 0.0,
        "target_modules": ["refiner_proj"]
      }
    },
    "trainable_modules": ["latent_refiner", "refiner_adapter_shared"]
  },
  "dataset": {
    "name": "synthetic_integer_sequences",
    "settings": {
      "num_examples": 32,
      "sequence_length": 10,
      "eval_fraction": 0.25,
      "seed": 14
    }
  },
  "training": {
    "batch_size": 4,
    "num_epochs": 1,
    "max_steps": 4,
    "learning_rate": 0.001,
    "weight_decay": 0.0,
    "seed": 14,
    "eval_interval_steps": 2,
    "checkpoint_interval_steps": 2
  },
  "output": {
    "dir": "outputs/shared_recurrence"
  }
}
